# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
JWT_SECRET=replace-with-256-bit-random-hex        # generated by make setup
USER_PASSWORD_HASH=replace-with-bcrypt-hash        # generated by make setup

# ── Model config ──────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-5
MAX_TOKENS=8192

# ── Storage paths ─────────────────────────────────────────────────────────────
DATA_DIR=./backend/data
MEMORY_DIR=./backend/data/memory
CHROMA_DIR=./backend/data/chroma
DB_PATH=./backend/data/futuro.db

# ── Memory behavior ───────────────────────────────────────────────────────────
GIT_AUTO_COMMIT=true                               # Auto-commit memory updates

# ── Development ───────────────────────────────────────────────────────────────
DEBUG=true
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000

# ── Optional: Gmail + Calendar (Phase 5) ──────────────────────────────────────
# GMAIL_OAUTH_CREDENTIALS_FILE=credentials.json
# GOOGLE_CALENDAR_OAUTH_CREDENTIALS_FILE=credentials.json

# ── Optional: Embedding model (default: chromadb built-in) ────────────────────
# EMBEDDING_MODEL=text-embedding-3-small           # Requires OPENAI_API_KEY
# OPENAI_API_KEY=sk-...

# ── Job Scout ─────────────────────────────────────────────────────────────────
SCOUT_ENABLED=true
SCOUT_DEFAULT_LOCATION=San Francisco, CA
SCOUT_DEFAULT_SITES=linkedin,indeed,glassdoor

# ── Provider routing ──────────────────────────────────────────────────────────
# Global: "claude" | "ollama" | "auto"
# "auto" = use Ollama if running, else Claude
LLM_PROVIDER=auto

# Per-task overrides (optional — leave blank to use LLM_PROVIDER)
# CHAT_PROVIDER=ollama
# CLASSIFY_PROVIDER=ollama
# SCORE_PROVIDER=claude
# EMBED_PROVIDER=ollama

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120.0
OLLAMA_KEEP_ALIVE=10m
